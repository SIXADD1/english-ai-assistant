# 服务器端口
PORT=3001
NODE_ENV=production

# JWT 密钥（生产环境请随机生成，如 openssl rand -hex 32）
JWT_SECRET=change-this-to-a-random-string

# 跨域来源（逗号分隔，必须包含你的域名和 IP）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://你的服务器IP,http://你的域名

# PostgreSQL 数据库连接（用户名/密码/数据库名 替换为宝塔中创建的）
DATABASE_URL=postgresql://postgres:你的数据库密码@localhost:5432/cet_writing

# DeepSeek API Key（在管理界面配置，此处可留空）
DEEPSEEK_API_KEY=

# AI 服务地址
AI_SERVICE_URL=http://localhost:8000

# 后端服务地址
BACKEND_URL=http://localhost:3001
